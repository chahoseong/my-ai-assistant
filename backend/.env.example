# 애플리케이션 실행 환경입니다. 로컬 개발에서는 local을 사용합니다.
APP_ENV=local

# 세션 쿠키를 HTTPS 연결에서만 전송할지 결정합니다. local 이외 환경에서는 true여야 합니다.
SESSION_COOKIE_SECURE=false

# 브라우저 요청을 허용할 Origin을 쉼표로 구분해 지정합니다.
AUTH_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 개발용 PostgreSQL 데이터베이스 연결 URL입니다.
DATABASE_URL=postgresql+asyncpg://assistant:assistant@127.0.0.1:5432/assistant_dev

# 테스트 전용 PostgreSQL 데이터베이스 연결 URL입니다. DATABASE_URL과 다른 데이터베이스여야 합니다.
TEST_DATABASE_URL=postgresql+asyncpg://assistant:assistant@127.0.0.1:5432/assistant_test

# LLM 서비스에 요청할 모델 이름입니다.
LLM_MODEL_NAME=google/gemma-4-E4B-it-qat-q4_0-gguf

# OpenAI 호환 LLM API의 기본 URL입니다.
LLM_BASE_URL=http://127.0.0.1:8080/v1

# OpenAI 호환 LLM API의 인증 키입니다.
LLM_API_KEY=llama.cpp

# 로컬 GGUF 모델 파일의 절대 경로입니다.
LLAMA_MODEL_PATH=

# PostgreSQL exporter가 데이터베이스에 연결할 때 사용하는 비밀번호입니다. 실제 값은 커밋하지 않습니다.
POSTGRES_EXPORTER_PASSWORD=
