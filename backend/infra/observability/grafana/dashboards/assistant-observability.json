{
  "uid": "assistant-observability",
  "title": "Assistant Observability",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"id":1,"type":"row","title":"Service health","gridPos":{"x":0,"y":0,"w":24,"h":1}},
    {"id":2,"type":"stat","title":"Scrape health","description":"애플리케이션과 PostgreSQL exporter가 모두 Prometheus에 수집되고 있나요?","gridPos":{"x":0,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"min(up{job=~\"my-ai-assistant|postgres\"})"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":3,"type":"timeseries","title":"Request rate","description":"서비스가 초당 수신하는 API 요청 수입니다.","gridPos":{"x":6,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(http_requests_total{job=\"my-ai-assistant\"}[5m])) or vector(0)"}],"fieldConfig":{"defaults":{"unit":"reqps"}}},
    {"id":4,"type":"timeseries","title":"Error rate","description":"최근 API 요청 중 5xx 오류로 끝난 비율입니다.","gridPos":{"x":12,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"(100 * sum(rate(http_requests_total{job=\"my-ai-assistant\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"my-ai-assistant\"}[5m])), 1e-9)) or vector(0)"}],"fieldConfig":{"defaults":{"unit":"percent"}}},
    {"id":5,"type":"timeseries","title":"HTTP request duration p95","description":"최근 일반 HTTP API 요청 중 느린 5%가 완료되기까지 걸린 시간입니다. 스트리밍 메시지 요청은 TTFT 및 LLM end-to-end latency 패널에서 별도로 확인합니다.","gridPos":{"x":18,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"my-ai-assistant\",path!=\"/api/conversations/{conversation_id}/messages\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":6,"type":"row","title":"LLM","gridPos":{"x":0,"y":9,"w":24,"h":1}},
    {"id":7,"type":"timeseries","title":"LLM time to first token p95","description":"최근 LLM 스트림 중 느린 5%가 첫 토큰을 생성하기까지 걸린 시간입니다.","gridPos":{"x":0,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(llm_first_token_seconds_bucket{job=\"my-ai-assistant\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":8,"type":"timeseries","title":"LLM end-to-end latency p95","description":"최근 LLM 스트림 중 느린 5%가 완료되기까지 걸린 전체 시간입니다.","gridPos":{"x":6,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(llm_stream_duration_seconds_bucket{job=\"my-ai-assistant\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":9,"type":"timeseries","title":"Stream failure rate","description":"초당 실패한 LLM 스트림 수입니다.","gridPos":{"x":12,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(llm_stream_failures_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":10,"type":"timeseries","title":"Generation rate","description":"초당 생성된 LLM 스트리밍 델타 수입니다.","gridPos":{"x":18,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(llm_stream_deltas_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":11,"type":"row","title":"Resources","gridPos":{"x":0,"y":18,"w":24,"h":1}},
    {"id":12,"type":"stat","title":"DB pool in use","description":"현재 애플리케이션 DB 연결 풀에서 사용 중인 연결 수입니다.","gridPos":{"x":0,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"db_pool_in_use{job=\"my-ai-assistant\"}"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":13,"type":"timeseries","title":"Lock conflict rate","description":"대화 쓰기가 충돌하여 409 응답으로 끝나는 초당 횟수입니다.","gridPos":{"x":6,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(conversation_lock_conflicts_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":14,"type":"stat","title":"PostgreSQL active connections","description":"개발 데이터베이스에 현재 연결된 백엔드 수입니다.","gridPos":{"x":12,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"pg_stat_database_numbackends{job=\"postgres\",datname=\"assistant_dev\"}"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":15,"type":"timeseries","title":"PostgreSQL cache hit ratio","description":"최근 PostgreSQL 버퍼 읽기 중 캐시에서 처리된 비율입니다.","gridPos":{"x":18,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"100 * sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=\"assistant_dev\"}[5m])) / clamp_min(sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=\"assistant_dev\"}[5m])) + sum(rate(pg_stat_database_blks_read{job=\"postgres\",datname=\"assistant_dev\"}[5m])), 1e-9)"}],"fieldConfig":{"defaults":{"unit":"percent"}}}
  ]
}
