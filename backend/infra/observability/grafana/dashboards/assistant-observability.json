{
  "uid": "assistant-observability",
  "title": "Assistant Observability",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"id":1,"type":"row","title":"Service health","gridPos":{"x":0,"y":0,"w":24,"h":1}},
    {"id":2,"type":"stat","title":"Scrape health","description":"애플리케이션과 데이터베이스의 상태 정보를 모두 수집할 수 있는 상태입니다. `1`은 모두 수집 가능, `0`은 하나 이상 수집 불가를 뜻합니다.","gridPos":{"x":0,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"min(up{job=~\"my-ai-assistant|postgres\"})"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":3,"type":"timeseries","title":"Request rate","description":"최근 5분 평균 초당 HTTP API 요청 수입니다.","gridPos":{"x":6,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(http_requests_total{job=\"my-ai-assistant\"}[5m])) or vector(0)"}],"fieldConfig":{"defaults":{"unit":"reqps"}}},
    {"id":4,"type":"timeseries","title":"Error rate","description":"최근 5분간 5xx 응답으로 끝난 HTTP API 요청의 비율입니다.","gridPos":{"x":12,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"(100 * sum(rate(http_requests_total{job=\"my-ai-assistant\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"my-ai-assistant\"}[5m])), 1e-9)) or vector(0)"}],"fieldConfig":{"defaults":{"unit":"percent"}}},
    {"id":5,"type":"timeseries","title":"HTTP request duration p95","description":"스트리밍 메시지를 제외한 HTTP API 요청의 최근 5분 p95 처리 시간입니다. 요청의 95%가 이 시간 안에 완료됩니다.","gridPos":{"x":18,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"my-ai-assistant\",path!=\"/api/conversations/{conversation_id}/messages\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":6,"type":"row","title":"LLM","gridPos":{"x":0,"y":9,"w":24,"h":1}},
    {"id":7,"type":"timeseries","title":"Model response start time p95","description":"모델 호출 후 답변의 첫 부분이 전달되기까지 걸린 최근 5분 p95 시간입니다.","gridPos":{"x":0,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(llm_first_token_seconds_bucket{job=\"my-ai-assistant\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":8,"type":"timeseries","title":"Model response completion time p95","description":"모델 호출 후 답변 전송이 완료되기까지 걸린 최근 5분 p95 시간입니다.","gridPos":{"x":6,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(llm_stream_duration_seconds_bucket{job=\"my-ai-assistant\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":9,"type":"timeseries","title":"Model response failure rate","description":"최근 5분 평균 초당 모델 응답 생성 실패 횟수입니다.","gridPos":{"x":12,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(llm_stream_failures_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":11,"type":"row","title":"Resources","gridPos":{"x":0,"y":18,"w":24,"h":1}},
    {"id":12,"type":"stat","title":"DB pool in use","description":"현재 애플리케이션이 사용 중인 DB 연결 풀 연결 수입니다.","gridPos":{"x":0,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"db_pool_in_use{job=\"my-ai-assistant\"}"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":13,"type":"timeseries","title":"Lock conflict rate","description":"동일 대화에 동시에 쓰기 요청이 들어와 409 응답으로 끝난 최근 5분 평균 초당 횟수입니다.","gridPos":{"x":6,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(conversation_lock_conflicts_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":14,"type":"stat","title":"PostgreSQL connections","description":"선택한 PostgreSQL 데이터베이스에 현재 연결된 세션 수입니다.","gridPos":{"x":12,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(pg_stat_database_numbackends{job=\"postgres\",datname=~\"$database\"})"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":15,"type":"timeseries","title":"PostgreSQL cache hit ratio","description":"선택한 PostgreSQL 데이터베이스의 최근 버퍼 읽기 중 메모리 캐시에서 처리된 비율입니다.","gridPos":{"x":18,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"100 * sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=~\"$database\"}[5m])) / clamp_min(sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=~\"$database\"}[5m])) + sum(rate(pg_stat_database_blks_read{job=\"postgres\",datname=~\"$database\"}[5m])), 1e-9)"}],"fieldConfig":{"defaults":{"unit":"percent"}}}
  ],
  "templating": {
    "list": [
      {
        "name": "database",
        "label": "Database",
        "type": "query",
        "datasource": {"uid": "prometheus", "type": "prometheus"},
        "definition": "label_values(pg_stat_database_numbackends{job=\"postgres\"}, datname)",
        "query": {"qry": "label_values(pg_stat_database_numbackends{job=\"postgres\"}, datname)", "refId": "StandardVariableQuery"},
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {"text": "All", "value": "$__all"},
        "options": [],
        "refresh": 1,
        "hide": 0
      }
    ]
  }
}
