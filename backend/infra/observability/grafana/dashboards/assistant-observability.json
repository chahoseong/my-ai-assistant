{
  "uid": "assistant-observability",
  "title": "Assistant Observability",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"id":1,"type":"row","title":"Service health","gridPos":{"x":0,"y":0,"w":24,"h":1}},
    {"id":2,"type":"stat","title":"Scrape health","description":"Are both the application and PostgreSQL exporter being scraped?","gridPos":{"x":0,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"min(up{job=~\"my-ai-assistant|postgres\"})"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":3,"type":"timeseries","title":"Request rate","description":"How many API requests per second is the service receiving?","gridPos":{"x":6,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(http_requests_total{job=\"my-ai-assistant\"}[5m])) or vector(0)"}],"fieldConfig":{"defaults":{"unit":"reqps"}}},
    {"id":4,"type":"timeseries","title":"Error rate","description":"What percentage of recent API requests returned 5xx errors?","gridPos":{"x":12,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"(100 * sum(rate(http_requests_total{job=\"my-ai-assistant\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"my-ai-assistant\"}[5m])), 1e-9)) or vector(0)"}],"fieldConfig":{"defaults":{"unit":"percent"}}},
    {"id":5,"type":"timeseries","title":"HTTP request duration p95","description":"최근 일반 HTTP API 요청 중 느린 5%가 완료되기까지 걸린 시간입니다. 스트리밍 메시지 요청은 TTFT 및 LLM end-to-end latency 패널에서 별도로 확인합니다.","gridPos":{"x":18,"y":1,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"my-ai-assistant\",path!=\"/api/conversations/{conversation_id}/messages\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":6,"type":"row","title":"LLM","gridPos":{"x":0,"y":9,"w":24,"h":1}},
    {"id":7,"type":"timeseries","title":"LLM time to first token p95","description":"최근 LLM 스트림 중 느린 5%가 첫 토큰을 생성하기까지 걸린 시간입니다.","gridPos":{"x":0,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(llm_first_token_seconds_bucket{job=\"my-ai-assistant\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":8,"type":"timeseries","title":"LLM end-to-end latency p95","description":"최근 LLM 스트림 중 느린 5%가 완료되기까지 걸린 전체 시간입니다.","gridPos":{"x":6,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"histogram_quantile(0.95, sum by (le) (rate(llm_stream_duration_seconds_bucket{job=\"my-ai-assistant\"}[5m])))"}],"fieldConfig":{"defaults":{"unit":"s"}}},
    {"id":9,"type":"timeseries","title":"Stream failure rate","description":"How many LLM streams fail per second?","gridPos":{"x":12,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(llm_stream_failures_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":10,"type":"timeseries","title":"Generation rate","description":"How many streamed deltas are produced per second?","gridPos":{"x":18,"y":10,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(llm_stream_deltas_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":11,"type":"row","title":"Resources","gridPos":{"x":0,"y":18,"w":24,"h":1}},
    {"id":12,"type":"stat","title":"DB pool in use","description":"How many application database-pool connections are currently checked out?","gridPos":{"x":0,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"db_pool_in_use{job=\"my-ai-assistant\"}"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":13,"type":"timeseries","title":"Lock conflict rate","description":"How often do conversation writes conflict and return 409?","gridPos":{"x":6,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"sum(rate(conversation_lock_conflicts_total{job=\"my-ai-assistant\"}[5m]))"}],"fieldConfig":{"defaults":{"unit":"ops"}}},
    {"id":14,"type":"stat","title":"PostgreSQL active connections","description":"How many connections are active against the development database?","gridPos":{"x":12,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"pg_stat_database_numbackends{job=\"postgres\",datname=\"assistant_dev\"}"}],"fieldConfig":{"defaults":{"unit":"none"}}},
    {"id":15,"type":"timeseries","title":"PostgreSQL cache hit ratio","description":"What share of recent PostgreSQL buffer reads were served from cache?","gridPos":{"x":18,"y":19,"w":6,"h":8},"datasource":{"uid":"prometheus","type":"prometheus"},"targets":[{"refId":"A","expr":"100 * sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=\"assistant_dev\"}[5m])) / clamp_min(sum(rate(pg_stat_database_blks_hit{job=\"postgres\",datname=\"assistant_dev\"}[5m])) + sum(rate(pg_stat_database_blks_read{job=\"postgres\",datname=\"assistant_dev\"}[5m])), 1e-9)"}],"fieldConfig":{"defaults":{"unit":"percent"}}}
  ]
}
